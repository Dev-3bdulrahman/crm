{
  "name": "dev-3bdulrahman/crm",
  "description": "A complete CRM module for Laravel ERP — customers, leads, opportunities, pipelines & activities.",
  "type": "library",
  "version": "1.0.0",
  "license": "MIT",
  "authors": [
    {
      "name": "Abdulrahman",
      "homepage": "https://3bdulrahman.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2|^8.3",
    "laravel/framework": "^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Dev3bdulrahman\\Crm\\": "src/",
      "Dev3bdulrahman\\Crm\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Dev3bdulrahman\\Crm\\CrmServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
